{
  "compilerOptions": {
    "module": "CommonJS",
    "target": "ES2020",
    "esModuleInterop": true,
    "rootDir": "..",
    "rootDirs": [
      "./src",
      "../shared"
    ],
    "outDir": "./dist",
    "sourceMap": true,
    "inlineSources": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "paths": {
      "@shared/*": [
        "../shared/*"
      ],
      "@domain/*": [
        "./src/domain/*"
      ],
      "@infra/*": [
        "./src/infrastructure/*"
      ],
      "*": ["./*"]
    }
  }
}